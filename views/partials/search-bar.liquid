{% render "partials/header" %}
<form class="filter-columns">

  <section class="search-bar">

<h3>I'm looking for a Christmas gift for my boyfriend Marco</h3>

<p>
Perfect! And how old is your boyfriend?  
Reminder: you can always reply by using the chat 
</p>

<form action="/search" method="get">

<h2>Age</h2>

<button type="button">5-12 Child</button>
<button type="button" class="active">13-19 Teen</button>
<button type="button">20-39 Young adult</button>
<button type="button">40-84 Adult</button>
<button type="button">85+ Elderly</button>

<h2>How would you describe Marco?</h2>

<p>If you can't find the tag write it down</p>

<button type="button">Empathetic</button>
<button type="button" class="active">Dreamer</button>
<button type="button">Gritty</button>
<button type="button" class="active">Sensitive</button>
<button type="button">Stubborn</button>

<input
type="text"
name="message"
placeholder="Marco is a positive person"/>

<button type="submit">Search</button>

</form>
</section>


   <!-- Search bar-->
<section class="search-bar-sidebar">
  <form action="/search" method="get" id="giftCardFilterForm">

    <!-- PRICE RANGE -->
    <section class="filter-card">
      <h2>Price range (€)</h2>
      <input type="number" id="priceMin" placeholder="Min" min="0" step="1">
      <input type="number" id="priceMax" placeholder="Max" min="0" step="1">
    </section>

    <!-- HAVE vs DO -->
    <section class="filter-card">
      <h4>Have vs Do</h4>
      <button type="button" data-tag="have">Have</button>
      <button type="button" data-tag="do">Do</button>
    </section>

    <!-- TRADITIONAL vs EXPERIMENTAL -->
    <section class="filter-card">
      <h2>Traditional vs Experimental</h2>
      <button type="button" data-tag="traditional">Traditional</button>
      <button type="button" data-tag="experimental">Experimental</button>
    </section>

    <!-- HIDDEN SEARCH INPUT -->
    <input type="hidden" name="q" id="giftCardSearchInput" value="">

    <!-- FORM ACTION BUTTONS -->
    <section class="filter-actions">
      <button type="button" id="resetFilters">Reset</button>
      <button type="button" id="cancelFilters">Cancel</button>
      <button type="submit">Apply</button>
    </section>

  </form>
</section>

{% render "partials/footer" %}