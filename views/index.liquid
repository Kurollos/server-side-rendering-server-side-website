

  <!-- Zoek/filter functionaliteit -->
  {% render "partials/search-bar" %}

 <main class="categoriepagina">
  <section class="container">

    <section class="product-grid">
      {% for product in products %}
        <article class="product-card">
          <section class="product-image">
            <img src="{{ product.img | default: product.image }}" alt="{{ product.name }}">
          </section>
          <section class="product-info">
            <h2>{{ product.name }}</h2>
            <p class="prijs">€{{ product.amount }}</p>
            <p class="shop">
              Shop:
              <a href="{{ product.shop_url }}" target="_blank">{{ product.shop_name }}</a>
            </p>
            <p class="spotter">
              Spotter:
              {% if product.spotter_img %}
                <img src="{{ product.spotter_img }}" alt="{{ product.spotter }}">
              {% endif %}
              {{ product.spotter }}
            </p>
            <a href="/product/{{ product.slug }}" class="button">Bekijk product</a>
          </section>
        </article>
      {% endfor %}
    </section>

</main>